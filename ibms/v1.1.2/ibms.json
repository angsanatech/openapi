{
    "openapi": "3.0.3",
    "info": {
        "title": "iBMS API Documentation",
        "description": "This is the API documentation for the iBMS system, which provides access to various endpoints for managing and retrieving data related to the eBDN.",
        "version": "1.1.2-Build25May2026"
    },
    "servers": [
        {
            "url": "https://stgapi.bunkerflow.io",
            "description": "Staging"
        },
        {
            "url": "https://api.bunkerflow.io",
            "description": "Production"
        }
    ],
    "tags": [
        {
            "name": "iBMS",
            "description": "Endpoints related to nomination management"
        }
    ],
    "paths": {
        "/external/ibms/authentication": {
            "post": {
                "tags": [
                    "iBMS"
                ],
                "summary": "Authenticate user and get token",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AuthRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Authentication successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AuthResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Authentication failed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/external/ibms/v1.1/push/{operation}": {
            "description": "Create a nomination",
            "post": {
                "tags": [
                    "iBMS"
                ],
                "summary": "Create a new nomination",
                "parameters": [
                    {
                        "name": "operation",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "delivery",
                                "transfer",
                                "loading"
                            ]
                        },
                        "description": "[New]Type of operation being pushed."
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Nomination"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successful response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SuccessResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error"
                    }
                }
            },
            "put": {
                "tags": [
                    "iBMS"
                ],
                "summary": "Update a nomination",
                "parameters": [
                    {
                        "name": "operation",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "delivery",
                                "transfer",
                                "loading"
                            ]
                        },
                        "description": "[New]Type of operation being pushed."
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Nomination"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successful response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SuccessResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error"
                    }
                }
            }
        },
        "/external/ibms/v1.1/pull/{operation}/{stemNo}/{refItemNo}": {
            "description": "Retrieve completed document after nomination completion",
            "get": {
                "tags": [
                    "iBMS"
                ],
                "summary": "Retrieve completed eBDN document",
                "parameters": [
                    {
                        "name": "operation",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "delivery",
                                "transfer",
                                "loading"
                            ]
                        },
                        "description": "[New] Type of operation being pushed."
                    },
                    {
                        "name": "stemNo",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "refItemNo",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "attachment",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "all",
                                "bdn"
                            ],
                            "default": "bdn"
                        },
                        "description": "Optional attachment file name to retrieve."
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "oneOf": [
                                        {
                                            "$ref": "#/components/schemas/BDN"
                                        },
                                        {
                                            "$ref": "#/components/schemas/Loading"
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error"
                    }
                }
            }
        },
        "/external/ibms/v1.1/webhook/register": {
            "post": {
                "tags": [
                    "iBMS"
                ],
                "summary": "Register a webhook endpoint for receiving push events from the iBMS server.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "callbackUrl"
                                ],
                                "properties": {
                                    "callbackUrl": {
                                        "type": "string",
                                        "format": "uri",
                                        "example": "https://client.com/my-callback"
                                    },
                                    "events": {
                                        "type": "array",
                                        "items": {
                                            "type": "string",
                                            "enum": [
                                                "operation.alongside",
                                                "operation.castoff",
                                                "operation.complete"
                                            ]
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Webhook registered successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "webhookId": {
                                            "type": "string",
                                            "example": "wh_123456"
                                        },
                                        "webhookToken": {
                                            "type": "string",
                                            "example": "whsec_abc123",
                                            "description": "Secret token used to verify webhook calls."
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/webhook/event": {
            "post": {
                "tags": [
                    "Webhook Events"
                ],
                "summary": "Webhook notification on iBMS events",
                "description": "Push notification from iBMS server to the API client on registered events.",
                "parameters": [
                    {
                        "name": "Authorization",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "Bearer whsec_abc123"
                        },
                        "description": "Bearer token generated specifically for webhook delivery by iBMS. This token is NOT the same as the API access token used by clients."
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "event",
                                    "eventId",
                                    "eventData"
                                ],
                                "properties": {
                                    "event": {
                                        "type": "string",
                                        "example": "operation.complete",
                                        "description": "Name of the webhook event."
                                    },
                                    "eventId": {
                                        "type": "string",
                                        "example": "ev_123456",
                                        "description": "Unique webhook event identifier for idempotency. The same event may be delivered multiple times. Clients must ensure idempotency using this eventId."
                                    },
                                    "eventData": {
                                        "description": "Event-specific payload.",
                                        "oneOf": [
                                            {
                                                "$ref": "#/components/schemas/EventOperationAlongside"
                                            },
                                            {
                                                "$ref": "#/components/schemas/EventOperationCastoff"
                                            },
                                            {
                                                "$ref": "#/components/schemas/EventOperationComplete"
                                            }
                                        ]
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Webhook received successfully"
                    },
                    "401": {
                        "description": "Invalid authentication token"
                    }
                }
            }
        }
    },
