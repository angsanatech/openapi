                "oneOf": [
                    {
                        "$ref": "#/components/schemas/EventOperationAlongside"
                    },
                    {
                        "$ref": "#/components/schemas/EventOperationCastoff"
                    },
                    {
                        "oneOf": [
                            {
                                "$ref": "#/components/schemas/BDN"
                            },
                            {
                                "$ref": "#/components/schemas/Loading"
                            }
                        ],
                        "description": "Returned when event = operation.complete. Matches GET document response."
                    }
                ]
            },
            "EventOperationAlongside": {
                "type": "object",
                "properties": {
                    "stemNo": {
                        "type": "string",
                        "example": "SO20250500127"
                    },
                    "refItemNo": {
                        "type": "number",
                        "example": 1
                    },
                    "timestamp": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-03-13T14:30:00+08:00",
                        "description": "Timestamp of the event in ISO 8601 format including timezone offset."
                    }
                }
            },
            "EventOperationCastoff": {
                "type": "object",
                "properties": {
                    "stemNo": {
                        "type": "string",
                        "example": "SO20250500127"
                    },
                    "refItemNo": {
                        "type": "number",
                        "example": 1
                    },
                    "timestamp": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-03-13T14:30:00+08:00",
                        "description": "Timestamp of the event in ISO 8601 format including timezone offset."
                    }
                }
            },
            "EventOperationComplete": {
                "type": "object",
                "properties": {
                    "operation": {
                        "type": "string",
                        "enum": [
                            "delivery",
                            "transfer",
                            "loading"
                        ]
                    },
                    "document": {
                        "oneOf": [
                            {
                                "$ref": "#/components/schemas/BDN"
                            },
                            {
                                "$ref": "#/components/schemas/Loading"
                            }
                        ]
                    }
                }
            }
        }
    }
}